# Copy each of these into Vercel -> Project -> Settings -> Environment Variables.
# Never commit real values: .env is gitignored, this .env.example is only a template.

# --- Where leads are delivered ---
LEAD_TO=invest@vitabahn.com

# --- SMTP (defaults shown are for Porkbun Email Hosting) ---
SMTP_HOST=smtp.porkbun.com
SMTP_PORT=587
SMTP_USER=invest@vitabahn.com
SMTP_PASS=your-mailbox-password
# Address shown in the From: header. Defaults to SMTP_USER if left unset.
LEAD_FROM=invest@vitabahn.com

# --- Security: only these origins may call the endpoint (comma-separated) ---
ALLOWED_ORIGIN=https://vitabahn.com,https://www.vitabahn.com
