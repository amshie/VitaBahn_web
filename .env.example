# Copy each of these into Vercel -> Project -> Settings -> Environment Variables.
# Never commit real values: .env is gitignored, this .env.example is only a template.

# --- Where leads are delivered ---
LEAD_TO=invest@vitabahn.com

# --- SMTP (defaults shown are for Porkbun Email Hosting) ---
# SMTP_USER must be a REAL Porkbun mailbox you can authenticate with (paid Email
# Hosting). LEAD_FROM must EQUAL SMTP_USER — Porkbun rejects a "From" address that
# differs from the authenticated mailbox.
SMTP_HOST=smtp.porkbun.com
SMTP_PORT=587
SMTP_USER=your-mailbox@vitabahn.com
SMTP_PASS=your-mailbox-password
# Address shown in the From: header. Must match SMTP_USER.
LEAD_FROM=your-mailbox@vitabahn.com

# --- Security: only these origins may call the endpoint (comma-separated) ---
ALLOWED_ORIGIN=https://www.vitabahn.com,https://vitabahn.com

# --- Optional: password-gate the WHOLE site (leave unset = site is public) ---
# When set, visitors must enter this password (HTTP Basic Auth) before the page
# loads. The lead-form API stays open so submissions still work. See middleware.js.
SITE_PASSWORD=
