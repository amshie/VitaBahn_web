# Copy each of these into Vercel -> Project -> Settings -> Environment Variables.
# Never commit real values: .env is gitignored, this .env.example is only a template.

# --- Where leads are delivered ---
LEAD_TO=info@vitabahn.com

# --- SMTP (defaults shown are for Porkbun Email Hosting) ---
# SMTP_USER must be a REAL Porkbun mailbox you can authenticate with (paid Email
# Hosting). LEAD_FROM must EQUAL SMTP_USER — Porkbun rejects a "From" address that
# differs from the authenticated mailbox.
SMTP_HOST=smtp.porkbun.com
SMTP_PORT=587
SMTP_USER=your-mailbox@vitabahn.com
SMTP_PASS=your-mailbox-password
# Address shown in the From: header. Must match SMTP_USER.
LEAD_FROM=your-mailbox@vitabahn.com

# --- Security: only these origins may call the endpoint (comma-separated) ---
ALLOWED_ORIGIN=https://www.vitabahn.com,https://vitabahn.com

# --- Optional: password-gate the WHOLE site (leave unset = site is public) ---
# When set, visitors must enter this password (HTTP Basic Auth) before the page
# loads. The lead-form API stays open so submissions still work. See middleware.js.
SITE_PASSWORD=

# --- Abuse controls for /api/lead (see api/lead.js) ---
# Proof-of-work secret: signs the anti-bot challenges. REQUIRED in production —
# if unset, the function falls back to an ephemeral per-instance secret and logs a
# warning (challenges then won't validate across serverless instances/restarts).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
POW_SECRET=
# Difficulty in leading zero bits (default 16 ≈ ~65k hashes, ~1s in-browser). Higher = harder for bots and users.
POW_BITS=16
# Fixed-window rate limit per client IP (defaults: 5 requests / 60 seconds).
RATE_MAX=5
RATE_WINDOW_SEC=60

# --- Durable store for rate limiting + proof-of-work replay (RECOMMENDED for production) ---
# Vercel serverless has no shared memory across instances, so the in-memory fallback
# only throttles per-instance. Provision Vercel KV or Upstash Redis and set EITHER pair
# below; api/lead.js auto-detects them. Without a store the function still runs (degraded).
# Vercel KV (Storage tab) injects these automatically when you link a KV database:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# …or Upstash Redis (REST):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Investor Access & Data Room system (api/access-request, api/auth/*, api/room/*,
# api/admin/*, /investor-room, /investor-console). REQUIRES Vercel hosting —
# it cannot run on Porkbun static hosting (no serverless functions).
# =============================================================================

# --- Database (REQUIRED in production) ---
# Vercel Postgres is now Neon-backed. Link a Neon database in the Vercel dashboard
# (Storage tab) and it injects POSTGRES_URL automatically; or paste a Neon URL here.
# When UNSET locally, the app falls back to embedded PGlite (see PGLITE_DATA_DIR).
POSTGRES_URL=
# DATABASE_URL= is also accepted (alias).

# --- Session signing (REQUIRED in production) ---
# Signs the HttpOnly session cookies. If unset, an ephemeral per-instance secret is
# used and sessions won't survive restarts/instances. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Session lifetime in seconds (default 43200 = 12h).
SESSION_TTL_SEC=43200

# --- Set-password invites (investor onboarding via email link) ---
# When you provision an investor, they receive an email with a single-use link to
# set their own password. Sending it uses the SMTP_* settings above — if SMTP is
# unset, provisioning still works and the console shows the one-time link to share
# manually.
# Public site origin used to build the link in the email; defaults to the first
# ALLOWED_ORIGIN entry (https://vitabahn.com).
PUBLIC_BASE_URL=
# How long a set-password / reset link stays valid, in seconds (default 7 days).
INVITE_TTL_SEC=604800

# --- First founder (Level 0) account bootstrap ---
# Set this temporarily, then POST {token,email,password,name} to /api/admin/bootstrap
# to create the first console admin. UNSET it again afterwards and redeploy.
# (Locally you can instead run: npm run create-admin -- you@vitabahn.com 'password' 'Name')
ADMIN_BOOTSTRAP_TOKEN=

# --- Booking links for the gateway (optional; Cal.com / Calendly URLs) ---
# Keep "requires confirmation" ON in the scheduler so every booking stays pending.
# NOTE: the Lead/Anchor (lead60) meeting is intentionally NOT auto-bookable — it is
# gated behind founder review, so there is no BOOKING_LEAD60 by design.
BOOKING_INTRO20=
BOOKING_QUALIFIED40=
BOOKING_STRATEGIC30=
BOOKING_FALLBACK=

# --- Local development only ---
# Persist the embedded PGlite store to a directory (else it is in-memory and resets).
# Used by scripts/create-admin.js and `vercel dev`. Not used in production.
PGLITE_DATA_DIR=
# Reminder: add your local origin to ALLOWED_ORIGIN when developing, e.g.
# ALLOWED_ORIGIN=https://vitabahn.com,https://www.vitabahn.com,http://localhost:3000
